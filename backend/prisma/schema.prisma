generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Operator {
  id                 String           @id @default(uuid())
  name               String
  tradingName        String?
  registrationNumber String           @unique
  vatNumber          String?
  contactPerson      String
  contactEmail       String
  contactPhone       String
  physicalAddress    String           @db.NVarChar(Max)
  region             String
  status             String           @default("active")
  logoUrl            String?          @db.NVarChar(Max)
  onboardedAt        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  drivers              Driver[]
  documents            Document[]
  fleets               Fleet[]
  importJobs           ImportJob[]
  incidents            Incident[]
  maintenanceRecords   MaintenanceRecord[]
  maintenanceSchedules MaintenanceSchedule[]
  repairJobs           RepairJob[]
  repairProviders      RepairProvider[]
  users                User[]
  vehicles             Vehicle[]
  wallet               Wallet?
  auditLogs            AuditLog[]
  tags                 Tag[]
  tagHistories         TagHistory[]
  costCentres          CostCentre[]
  contracts            VehicleContract[]
  contractPayments     ContractPayment[]
  insurers             Insurer[]
  handovers            VehicleHandover[]
}

model VehicleHandover {
  id                  String    @id @default(uuid())
  operatorId          String
  vehicleId           String
  driverId            String?
  fleetId             String?
  handoverNumber      String    @unique
  handoverType        String
  handoverDatetime    DateTime
  odometerReading     Int?
  fuelLevel           String?
  exteriorCondition   String?
  interiorCondition   String?
  damageNotes         String?   @db.NVarChar(Max)
  equipmentChecklist  String?   @db.NVarChar(Max)
  driverSignature     String?   @db.NVarChar(Max)
  managerSignature    String?   @db.NVarChar(Max)
  photos              String?   @db.NVarChar(Max)
  notes               String?   @db.NVarChar(Max)
  latitude            Decimal?  @db.Decimal(10, 7)
  longitude           Decimal?  @db.Decimal(10, 7)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  driver   Driver?  @relation(fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fleet    Fleet?   @relation(fields: [fleetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Insurer {
  id            String    @id @default(uuid())
  operatorId    String
  companyName   String
  claimsPhone   String?
  claimsEmail   String?
  generalPhone  String?
  brokerName    String?
  brokerPhone   String?
  brokerEmail   String?
  notes         String?   @db.NVarChar(Max)
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  operator Operator  @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles Vehicle[]
}

model Fleet {
  id              String            @id @default(uuid())
  operatorId      String
  name            String
  code            String?
  contactPerson   String?
  contactPhone    String?
  contactEmail    String?
  region          String?
  monthlyBudget   Decimal?          @db.Decimal(12, 2)
  status          String            @default("active")
  costCentreId    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?

  operator             Operator              @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  costCentre           CostCentre?           @relation(fields: [costCentreId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  drivers              Driver[]
  fuelTransactions     FuelTransaction[]
  incidents            Incident[]
  maintenanceRecords   MaintenanceRecord[]
  repairJobs           RepairJob[]
  vehicles             Vehicle[]
  handovers            VehicleHandover[]
}

model Vehicle {
  id                 String            @id @default(uuid())
  operatorId         String
  fleetId            String
  registrationNumber String
  vinNumber          String?
  make               String
  model              String
  year               Int
  colour             String?
  fuelType           String
  tankCapacity       Decimal           @db.Decimal(6, 2)
  currentOdometer    Int?
  status             String            @default("active")
  tagStatus          String            @default("unassigned")
  tagNumber          String?
  costCentreId       String?
  insurerId          String?
  ownershipType      String?
  leaseExpiry        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  operator             Operator              @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fleet                Fleet                 @relation(fields: [fleetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  costCentre           CostCentre?           @relation(fields: [costCentreId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  insurer              Insurer?              @relation(fields: [insurerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fuelTransactions     FuelTransaction[]
  incidents            Incident[]
  maintenanceRecords   MaintenanceRecord[]
  maintenanceSchedules MaintenanceSchedule[]
  repairJobs           RepairJob[]
  tags                 Tag[]
  contracts            VehicleContract[]
  equipment            VehicleEquipment[]
  handovers            VehicleHandover[]

  @@index([operatorId, status])
  @@index([operatorId, fleetId])
}

model VehicleEquipment {
  id             String    @id @default(uuid())
  vehicleId      String
  equipmentType  String
  status         String    @default("present")
  expiryDate     DateTime?
  lastChecked    DateTime?
  notes          String?   @db.NVarChar(Max)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([vehicleId, equipmentType])
}

model Driver {
  id                String            @id @default(uuid())
  operatorId        String
  fleetId           String
  firstName         String
  lastName          String
  saIdNumber        String?
  passportNumber    String?
  mobileNumber      String
  email             String?
  driverPin         String
  licenceNumber     String?
  licenceCode       String?
  licenceExpiry     DateTime?
  prdpNumber        String?
  prdpExpiry        DateTime?
  status            String            @default("active")
  dailySpendLimit   Decimal?          @db.Decimal(10, 2)
  monthlySpendLimit Decimal?          @db.Decimal(10, 2)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  operator         Operator          @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fleet            Fleet             @relation(fields: [fleetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fuelTransactions FuelTransaction[]
  incidents        Incident[]
  repairJobs       RepairJob[]
  handovers        VehicleHandover[]

  @@index([operatorId, fleetId])
}

model User {
  id           String         @id @default(uuid())
  operatorId   String?
  email        String         @unique
  passwordHash String
  role         String         @default("operator_admin")
  firstName    String
  lastName     String
  mobileNumber String?
  isActive     Boolean        @default(true)
  status       String         @default("active")
  lastLoginAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deletedAt    DateTime?

  operator      Operator?      @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notifications Notification[]
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  operatorId  String
  action      String
  entityType  String
  entityId    String
  changes     String?  @db.NVarChar(Max)
  description String?  @db.NVarChar(Max)
  ipAddress   String?
  userAgent   String?  @db.NVarChar(Max)
  metadata    String?  @db.NVarChar(Max)
  createdAt   DateTime @default(now())

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([operatorId, entityType, entityId, createdAt])
  @@index([userId, createdAt])
}

model FuelTransaction {
  id              String   @id @default(uuid())
  operatorId      String
  fleetId         String
  vehicleId       String
  driverId        String
  transactionDate DateTime @default(now())
  litresFilled    Decimal  @db.Decimal(8, 2)
  pricePerLitre   Decimal  @db.Decimal(8, 4)
  totalAmount     Decimal  @db.Decimal(10, 2)
  fuelType        String
  odometer        Int?
  siteCode        String?
  siteName        String?
  status          String   @default("approved")
  fuelEfficiency  Decimal? @db.Decimal(6, 2)
  anomalyFlags    String   @default("[]") @db.NVarChar(Max)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  driver  Driver  @relation(fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fleet   Fleet   @relation(fields: [fleetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model ImportJob {
  id             String      @id @default(uuid())
  operatorId     String
  uploadedBy     String
  entityType     String
  fileName       String
  fileUrl        String?     @db.NVarChar(Max)
  columnMapping  String      @default("{}") @db.NVarChar(Max)
  totalRows      Int
  importedCount  Int         @default(0)
  skippedCount   Int         @default(0)
  failedCount    Int         @default(0)
  errorReportUrl String?     @db.NVarChar(Max)
  status         String      @default("pending")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  operator   Operator    @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  importRows ImportRow[]

  @@index([operatorId, status])
}

model ImportRow {
  id                 String    @id @default(uuid())
  importJobId        String
  rowNumber          Int
  rawData            String    @db.NVarChar(Max)
  mappedData         String    @default("{}") @db.NVarChar(Max)
  validationErrors   String?   @db.NVarChar(Max)
  validationWarnings String?   @db.NVarChar(Max)
  duplicateOf        String?
  resolution         String?
  status             String    @default("pending")
  createdAt          DateTime  @default(now())

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([importJobId, status])
  @@index([importJobId, rowNumber])
}

model Notification {
  id         String    @id @default(uuid())
  userId     String
  operatorId String?
  type       String
  title      String
  message    String    @db.NVarChar(Max)
  isRead     Boolean   @default(false)
  readAt     DateTime?
  metadata   String?   @db.NVarChar(Max)
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}


model RepairJob {
  id                  String          @id @default(uuid())
  operatorId          String
  vehicleId           String
  driverId            String?
  fleetId             String
  incidentId          String?
  repairNumber        String          @unique
  repairType          String
  priority            String
  status              String          @default("reported")
  description         String          @db.NVarChar(Max)
  diagnosisNotes      String?         @db.NVarChar(Max)
  odometerAtReport    Int?
  isDrivable          Boolean
  breakdownLatitude   Decimal?        @db.Decimal(10, 7)
  breakdownLongitude  Decimal?        @db.Decimal(10, 7)
  providerId          String?
  approvedQuoteId     String?
  estimatedCompletion DateTime?
  actualCompletion    DateTime?
  totalCost           Decimal?        @db.Decimal(12, 2)
  labourCost          Decimal?        @db.Decimal(10, 2)
  partsCost           Decimal?        @db.Decimal(10, 2)
  towingCost          Decimal?        @db.Decimal(10, 2)
  vatAmount           Decimal?        @db.Decimal(10, 2)
  warrantyMonths      Int?
  warrantyExpiry      DateTime?
  downtimeDays        Int?
  cancellationReason  String?         @db.NVarChar(Max)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  driver         Driver?         @relation(fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fleet          Fleet           @relation(fields: [fleetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operator       Operator        @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  repairProvider RepairProvider? @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  repairQuotes   RepairQuote[]
  workLogs       RepairWorkLog[]

  @@index([operatorId, status])
  @@index([operatorId, vehicleId])
}

model RepairProvider {
  id              String        @id @default(uuid())
  operatorId      String
  name            String
  contactPerson   String?
  contactPhone    String
  contactEmail    String?
  address         String?       @db.NVarChar(Max)
  specialisations String        @default("[]") @db.NVarChar(Max)
  rating          Decimal?      @db.Decimal(3, 2)
  status          String        @default("active")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  operator     Operator      @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  repairJobs   RepairJob[]
  repairQuotes RepairQuote[]
}

model RepairQuote {
  id             String         @id @default(uuid())
  repairJobId    String
  providerId     String
  quoteNumber    String?
  lineItems      String         @default("[]") @db.NVarChar(Max)
  labourTotal    Decimal        @db.Decimal(10, 2)
  partsTotal     Decimal        @db.Decimal(10, 2)
  totalExclVat   Decimal        @db.Decimal(12, 2)
  vatAmount      Decimal        @db.Decimal(10, 2)
  totalInclVat   Decimal        @db.Decimal(12, 2)
  estimatedDays  Int?
  warrantyMonths Int?
  validUntil     DateTime?
  documentUrl    String?        @db.NVarChar(Max)
  status         String         @default("pending")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  repairProvider RepairProvider @relation(fields: [providerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  repairJob      RepairJob      @relation(fields: [repairJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model RepairWorkLog {
  id            String    @id @default(uuid())
  repairJobId   String
  userId        String
  note          String    @db.NVarChar(Max)
  photosJson    String?   @db.NVarChar(Max)
  partsReplaced String?   @db.NVarChar(Max)
  createdAt     DateTime  @default(now())

  repairJob RepairJob @relation(fields: [repairJobId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Incident {
  id                   String    @id @default(uuid())
  operatorId           String
  vehicleId            String
  driverId             String?
  fleetId              String
  incidentNumber       String    @unique
  incidentDate         DateTime
  incidentType         String
  description          String    @db.NVarChar(Max)
  location             String?   @db.NVarChar(Max)
  latitude             Decimal?  @db.Decimal(10, 7)
  longitude            Decimal?  @db.Decimal(10, 7)
  policeCaseNumber     String?
  insuranceClaimNumber String?
  claimStatus          String?
  claimAmount          Decimal?  @db.Decimal(12, 2)
  payoutAmount         Decimal?  @db.Decimal(12, 2)
  costEstimate         Decimal?  @db.Decimal(12, 2)
  downtimeStart        DateTime?
  downtimeEnd          DateTime?
  downtimeDays         Int?
  thirdPartyInvolved   Boolean   @default(false)
  thirdPartyDetails    String?   @db.NVarChar(Max)
  severity             String
  status               String    @default("reported")
  notes                String?   @db.NVarChar(Max)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  driver   Driver?  @relation(fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fleet    Fleet    @relation(fields: [fleetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model MaintenanceRecord {
  id                  String    @id @default(uuid())
  operatorId          String
  vehicleId           String
  fleetId             String
  maintenanceType     String
  description         String    @db.NVarChar(Max)
  provider            String?
  cost                Decimal?  @db.Decimal(12, 2)
  vatAmount           Decimal?  @db.Decimal(10, 2)
  odometer            Int?
  serviceDate         DateTime
  nextServiceDate     DateTime?
  nextServiceOdometer Int?
  isScheduled         Boolean   @default(false)
  status              String    @default("completed")
  notes               String?   @db.NVarChar(Max)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fleet    Fleet    @relation(fields: [fleetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model MaintenanceSchedule {
  id                  String    @id @default(uuid())
  operatorId          String
  vehicleId           String
  maintenanceType     String
  intervalMonths      Int?
  intervalKm          Int?
  lastServiceDate     DateTime?
  lastServiceOdometer Int?
  nextDueDate         DateTime?
  nextDueOdometer     Int?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Document {
  id           String    @id @default(uuid())
  operatorId   String
  entityType   String
  entityId     String
  documentType String
  fileName     String
  fileUrl      String    @db.NVarChar(Max)
  fileSize     Int
  mimeType     String
  uploadedBy   String
  description  String?   @db.NVarChar(Max)
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  operator Operator @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([operatorId, entityType, entityId])
}

model Wallet {
  id                  String              @id @default(uuid())
  operatorId          String              @unique
  balance             Decimal             @default(0) @db.Decimal(12, 2)
  creditLimit         Decimal             @default(0) @db.Decimal(12, 2)
  lowBalanceThreshold Decimal             @default(500) @db.Decimal(12, 2)
  currency            String              @default("ZAR")
  status              String              @default("active")
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  operator           Operator            @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  walletTransactions WalletTransaction[]
}

model WalletTransaction {
  id            String   @id @default(uuid())
  walletId      String
  type          String
  amount        Decimal  @db.Decimal(12, 2)
  balanceBefore Decimal  @db.Decimal(12, 2)
  balanceAfter  Decimal  @db.Decimal(12, 2)
  reference     String?
  description   String?  @db.NVarChar(Max)
  status        String   @default("completed")
  processedAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Tag Lifecycle ────────────────────────────────────────────────────────────

model Tag {
  id                  String    @id @default(uuid())
  operatorId          String
  tagNumber           String
  vehicleId           String?
  status              String    @default("unassigned")
  blockedReason       String?   @db.NVarChar(Max)
  issuedDate          DateTime?
  expiryDate          DateTime?
  activatedAt         DateTime?
  blockedAt           DateTime?
  lastUsedAt          DateTime?
  lastUsedForecourtId String?
  notes               String?   @db.NVarChar(Max)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  operator  Operator     @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle   Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  histories TagHistory[]

  @@unique([operatorId, tagNumber])
}

model TagHistory {
  id             String   @id @default(uuid())
  tagId          String
  operatorId     String
  action         String
  fromVehicleId  String?
  toVehicleId    String?
  previousStatus String?
  newStatus      String
  reason         String?  @db.NVarChar(Max)
  performedBy    String
  createdAt      DateTime @default(now())

  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operator Operator @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

// ─── Cost Centres ─────────────────────────────────────────────────────────────

model CostCentre {
  id           String    @id @default(uuid())
  operatorId   String
  name         String
  code         String
  description  String?   @db.NVarChar(Max)
  budget       Decimal?  @db.Decimal(12, 2)
  budgetPeriod String?
  parentId     String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  operator Operator     @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parent   CostCentre?  @relation("CostCentreHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children CostCentre[] @relation("CostCentreHierarchy")
  vehicles Vehicle[]
  fleets   Fleet[]

  @@unique([operatorId, code])
}

// ─── Vehicle Contracts ────────────────────────────────────────────────────────

model VehicleContract {
  id                 String    @id @default(uuid())
  operatorId         String
  vehicleId          String
  contractType       String
  provider           String
  contractNumber     String?
  startDate          DateTime
  endDate            DateTime
  monthlyAmount      Decimal?  @db.Decimal(12, 2)
  totalContractValue Decimal?  @db.Decimal(14, 2)
  depositPaid        Decimal?  @db.Decimal(12, 2)
  residualValue      Decimal?  @db.Decimal(12, 2)
  escalationRate     Decimal?  @db.Decimal(5, 2)
  paymentDay         Int?
  terms              String?   @db.NVarChar(Max)
  renewalType        String?
  renewalNoticeDays  Int?
  dailyKmLimit       Int?
  monthlyKmLimit     Int?
  totalKmLimit       Int?
  excessKmRate       Decimal?  @db.Decimal(10, 2)
  kmAtStart          Int?
  status             String    @default("active")
  terminationReason  String?   @db.NVarChar(Max)
  terminationDate    DateTime?
  notes              String?   @db.NVarChar(Max)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  operator Operator          @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicle  Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments ContractPayment[]
}

model ContractPayment {
  id            String   @id @default(uuid())
  contractId    String
  operatorId    String
  paymentDate   DateTime
  amount        Decimal  @db.Decimal(12, 2)
  vatAmount     Decimal? @db.Decimal(10, 2)
  paymentMethod String?
  reference     String?
  status        String   @default("completed")
  notes         String?  @db.NVarChar(Max)
  createdAt     DateTime @default(now())

  contract VehicleContract @relation(fields: [contractId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  operator Operator        @relation(fields: [operatorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}
